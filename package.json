{
  "name": "grrrignote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev/dev-with-shared-link.js",
    "dev:raw": "next dev",
    "db:migrate": "node scripts/db/migrate-runner.js up",
    "db:migrate:down": "node scripts/db/migrate-runner.js down 1",
    "db:migrate:new": "node scripts/db/migrate-runner.js create",
    "db:preflight": "node scripts/db/preflight.js",
    "db:sync-allergens": "node scripts/db/sync-allergens.js",
    "db:seed": "node scripts/db/seed.js",
    "db:ensure-personal-access": "node scripts/users/ensure-personal-access.js",
    "db:assert-personal-access": "node scripts/users/assert-personal-access.js",
    "db:setup": "npm run db:migrate && npm run db:sync-allergens && npm run db:seed",
    "build": "next build --webpack",
    "postbuild": "node scripts/deploy/postbuild-production.js",
    "start": "next start",
    "users:create": "node scripts/users/create-user.js",
    "users:test-link:generate": "node scripts/users/test-link-generate.js",
    "users:test-link:revoke": "node scripts/users/test-link-revoke.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:users": "node --test scripts/users/ensure-personal-access.test.js lib/premium-entitlement-core.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "deploy:prod": "vercel deploy . --prod -y"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.18.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^4.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.0"
  }
}
